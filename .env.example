# ── Server ──────────────────────────────────────────────────────────────────
API_PORT=8790
CORS_ORIGINS=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://campaign_manager:password@localhost:5432/campaign_manager

# ── Encryption (AES-256-GCM) ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Storage ──────────────────────────────────────────────────────────────────
# Where pipeline artifacts (audio, transcripts, imports) are stored on disk
ARTIFACT_DIR=./data/artifacts

# ── Operational limits ────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=209715200
MAX_CONCURRENT_JOBS=3
