# ── Server ─────────────────────────────────────────────────────────────────
API_PORT=8790
DATA_DIR=./data

# ── Auth (leave blank to disable) ──────────────────────────────────────────
APP_TOKEN=

# ── CORS (comma-separated allowed origins; blank = localhost only) ──────────
CORS_ORIGINS=

# ── Upload / job limits ────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=209715200
MAX_CONCURRENT_JOBS=3
MAX_RETAINED_JOBS=100
JOB_RETENTION_MS=1800000
CAMPAIGN_DB_CACHE_MAX=10

# ── ASR provider: remote | local | groq | openai ──────────────────────────
ASR_PROVIDER=remote

# Remote SSH Whisper (ASR_PROVIDER=remote)
OLLAMA_SSH_KEY=~/.ssh/id_rsa
OLLAMA_SSH_USER=user
OLLAMA_SSH_HOST=192.168.1.100
REMOTE_AUDIO_DIR=/tmp/dnd-audio-in
REMOTE_OUT_DIR=/tmp/dnd-audio-out
WHISPER_MODEL=tiny
WHISPER_DEVICE=cuda
WHISPER_CHUNK_SECONDS=600

# Groq (ASR_PROVIDER=groq)
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_BASE=https://api.groq.com/openai/v1

# Max upload chunk size for API-based ASR (bytes; Groq/OpenAI cap is 25 MB)
ASR_API_CHUNK_BYTES=25165824

# ── Diarization ────────────────────────────────────────────────────────────
# auto | llm | pyannote
DIARIZATION_MODE=auto
DIARIZATION_ASR_MODEL=medium
DIARIZATION_ASR_DEVICE=cuda
DIARIZATION_COMPUTE_TYPE=float16
DIARIZATION_PYANNOTE_DEVICE=cuda
# Required when DIARIZATION_MODE=pyannote
PYANNOTE_HF_TOKEN=

# ── LLM providers ──────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
OLLAMA_BASE=http://localhost:11434

OPENAI_BASE=https://api.openai.com/v1
OPENAI_API_KEY=

ANTHROPIC_BASE=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_RETRY_MAX=4
ANTHROPIC_RETRY_BASE_MS=1200
ANTHROPIC_MIN_GAP_MS=900

GEMINI_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=

# ── Pipeline mode ──────────────────────────────────────────────────────────
# Set true to force all pipeline LLM calls through OpenAI regardless of Settings
PIPELINE_CHATGPT_ONLY=false
PIPELINE_OPENAI_MODEL=gpt-4o
PIPELINE_OPENAI_FALLBACK_MODEL=gpt-4o-mini
